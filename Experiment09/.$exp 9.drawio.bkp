    <mxGraphModel dx="2906" dy="1444" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="viL8XR5m36R2_ILlf4hx-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 48px;&quot;&gt;Ticket Booking System&lt;/font&gt;" vertex="1">
          <mxGeometry height="130" width="380" x="250" y="20" as="geometry" />
        </mxCell>
        <mxCell id="viL8XR5m36R2_ILlf4hx-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;1.FUNCTIONAL REQUIREMENTS:-&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="400" x="40" y="190" as="geometry" />
        </mxCell>
        <mxCell id="viL8XR5m36R2_ILlf4hx-7" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;div&gt;i.Users should be able to register and log in.&amp;nbsp;&lt;/div&gt;&lt;div&gt;ii.Users should be able to search events by:&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Event Title&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;City/Location&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Date&amp;nbsp;&lt;/div&gt;&lt;div&gt;iii.Users should be able to view event details:&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Description&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Cast&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Duration&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Ratings&amp;nbsp;&lt;/div&gt;&lt;div&gt;iv.System should display:&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Available seats&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Booked seats&amp;nbsp;&lt;/div&gt;&lt;div&gt;v.Users should be able to:&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Select seats&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Book tickets&amp;nbsp;&lt;/div&gt;&lt;div&gt;vi.System should:&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Lock seats temporarily during booking&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Prevent double booking&amp;nbsp;&lt;/div&gt;&lt;div&gt;vii.Users should be able to:&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;View booking history&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Download tickets&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="340" width="690" x="95" y="220" as="geometry" />
        </mxCell>
        <mxCell id="viL8XR5m36R2_ILlf4hx-8" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;2. NON FUNCTIONAL REQUIREMENT :-&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="370" x="90" y="560" as="geometry" />
        </mxCell>
        <mxCell id="viL8XR5m36R2_ILlf4hx-9" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div&gt;i.The system must support 100 Million Daily Active Users (DAU).&amp;nbsp;&lt;/div&gt;&lt;div&gt;ii.Search operations must have high availability.&amp;nbsp;&lt;/div&gt;&lt;div&gt;iii.Booking must ensure strong consistency.&amp;nbsp;&lt;/div&gt;&lt;div&gt;iv.System latency:&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Search &amp;lt; 200 ms&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Booking &amp;lt; 2 seconds&amp;nbsp;&lt;/div&gt;&lt;div&gt;v.System should be:&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Fault tolerant&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Highly scalable (microservices architecture)&amp;nbsp;&lt;/div&gt;&lt;div&gt;vi.Use caching (Redis) to improve performance.&amp;nbsp;&lt;/div&gt;&lt;div&gt;vii.Ensure secure transactions using HTTPS and authentication.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="630" x="95" y="670" as="geometry" />
        </mxCell>
        <mxCell id="viL8XR5m36R2_ILlf4hx-10" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;4.API DESIGNS:-&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="280" x="20" y="940" as="geometry" />
        </mxCell>
        <mxCell id="viL8XR5m36R2_ILlf4hx-11" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div&gt;i.User APIs:&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;POST /auth/signup&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;POST /auth/login&amp;nbsp;&lt;/div&gt;&lt;div&gt;ii.Event APIs:&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;GET /api/v1/events&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;GET /api/v1/events/{event_id}&lt;/div&gt;&lt;div&gt;iii.Search APIs:&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;GET /api/v1/events?city={city}&amp;amp;date={date}&amp;amp;title={title}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;iv.Seat APIs:&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;GET /api/v1/shows/{show_id}/seats&amp;nbsp;&lt;/div&gt;&lt;div&gt;v.Booking APIs:&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;POST /api/v1/bookings/lock&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;POST /api/v1/bookings/confirm&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;GET /api/v1/bookings&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;vi.Payment APIs:&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;POST /api/v1/payments&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="490" x="90" y="1090" as="geometry" />
        </mxCell>
        <mxCell id="viL8XR5m36R2_ILlf4hx-12" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;3.CORE ENTITIES:-&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="260" x="50" y="790" as="geometry" />
        </mxCell>
        <mxCell id="viL8XR5m36R2_ILlf4hx-13" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;User&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Event&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Venue&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Show&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Seat&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Booking&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Payment&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="170" x="95" y="870" as="geometry" />
        </mxCell>
        <mxCell id="viL8XR5m36R2_ILlf4hx-15" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;5.DATABASE SCHEMA:-&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="240" x="70" y="1290" as="geometry" />
        </mxCell>
        <mxCell id="viL8XR5m36R2_ILlf4hx-16" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div&gt;i. Users Table&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;user_id (PK)&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;name&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;email&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;ii. Events Table&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;event_id (PK)&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;title&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;description&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;language&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;rating&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;iii. Venues Table&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;venue_id (PK)&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;name&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;city&lt;/div&gt;&lt;div&gt;iv. Shows Table&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;show_id (PK)&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;event_id (FK)&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;venue_id (FK)&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;datetime&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;v. Seats Table&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;seat_id (PK)&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;show_id (FK)&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;status (available, locked, booked)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;vi. Bookings Table&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;booking_id (PK)&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;user_id (FK)&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;show_id (FK)&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;status&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;vii. Payments Table&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;payment_id (PK)&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;booking_id (FK)&amp;nbsp;&lt;/div&gt;&lt;div&gt;•&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;status&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="560" x="90" y="1580" as="geometry" />
        </mxCell>
